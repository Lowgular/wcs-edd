# Angular specific
/dist/
/out-tsc/
/tmp/
/coverage/
/e2e/test-output/
/.angular/
.angular/

# Node modules and dependency files
/node_modules/
/package-lock.json
/yarn.lock

# Environment files
/.env

# Angular CLI and build artefacts
/.angular-cli.json
/.ng/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# web-codegen-scorer writes these into the working directory (the repo root)
.web-codegen-scorer/
safety-web.log
*.log
# qmd local index (regenerable: qmd init && qmd collection add ./wiki --name wiki && qmd embed)
.qmd/

# qmd-assembled prompts (regenerate: node scripts/qmd-context.mjs)
tasks/generated/

# per-runner diagnostic dumps (agents/*.runner.mjs each overwrite a snapshot of their last run)
.run-debug/
